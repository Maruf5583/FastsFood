@{
    var cartCount = ViewBag.CartCount ?? 0;
    var cartTotal = ViewBag.CartTotal ?? 0;
}

<a href="/Cart/Index" class="nav-link position-relative">
    <i class="fas fa-shopping-cart"></i>
    @if (cartCount > 0)
    {
        <span class="cart-badge">@cartCount</span>
    }
</a>

<style>
    .cart-badge {
        position: absolute;
        top: 0;
        right: 0;
        background: #ff4757;
        color: white;
        border-radius: 50%;
        padding: 2px 6px;
        font-size: 11px;
        min-width: 18px;
        text-align: center;
    }
</style>