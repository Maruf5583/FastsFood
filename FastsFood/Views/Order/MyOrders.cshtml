@model List<FastsFood.Models.OrderHeader>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container my-5">
    <h1 class="mb-4">My Orders</h1>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var order in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h6 class="text-muted mb-1">Order #ORD-@order.Id.ToString("D6")</h6>
                                    <small class="text-muted">@order.OrderDate.ToString("MMM dd, yyyy")</small>
                                </div>
                                <div>
                                    @if (order.OrderStatus == "Confirmed")
                                    {
                                        <span class="badge bg-success">Confirmed</span>
                                    }
                                    else if (order.OrderStatus == "Pending")
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                    else if (order.OrderStatus == "Delivered")
                                    {
                                        <span class="badge bg-info">Delivered</span>
                                    }
                                    else if (order.OrderStatus == "Cancelled")
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <strong>Total: ৳@order.OrderTotal.ToString("0.00")</strong>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted">Payment: @order.PaymentStatus</small>
                            </div>

                            <a href="/Order/OrderDetails/@order.Id" class="btn btn-sm btn-outline-primary">
                                View Details
                            </a>
                            <a href="/Order/TrackOrder?orderId=@order.Id" class="btn btn-sm btn-outline-secondary">
                                Track Order
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state text-center py-5">
            <i class="fas fa-shopping-bag fa-4x text-muted mb-3"></i>
            <h3>No Orders Yet</h3>
            <p>You haven't placed any orders yet.</p>
            <a href="/Home/Menu" class="btn btn-primary">Start Shopping</a>
        </div>
    }
</div>

<style>
    .empty-state {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 60px;
    }
</style>