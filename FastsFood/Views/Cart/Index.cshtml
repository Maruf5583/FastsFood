@model List<FastsFood.Models.Cart>
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container my-5">
    <h1 class="mb-4">Shopping Cart</h1>
    
    @if (Model != null && Model.Any())
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body">
                        @foreach (var item in Model)
                        {
                            <div class="cart-item" id="cart-item-@item.ItemId">
                                <div class="row align-items-center">
                                    <div class="col-md-2">
                                        <img src="@(!string.IsNullOrEmpty(item.Item.ImageUrl) ? item.Item.ImageUrl : "/images/items/cover.jpg")"
                                             alt="@item.Item.Title" class="img-fluid rounded"
                                             onerror="this.src='/images/items/cover.jpg'">
                                    </div>
                                    <div class="col-md-4">
                                        <h5 class="mb-1">@item.Item.Title</h5>
                                        <p class="text-muted small">@item.Item.Category?.Title</p>
                                    </div>
                                    <div class="col-md-2">
                                        <span class="price">৳@item.Item.Price.ToString("0.00")</span>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="quantity-control">
                                            <button class="btn-quantity minus" onclick="updateQuantity(@item.ItemId, @(item.Count - 1))">-</button>
                                            <input type="number" class="quantity-input" value="@item.Count" id="qty-@item.ItemId" readonly>
                                            <button class="btn-quantity plus" onclick="updateQuantity(@item.ItemId, @(item.Count + 1))">+</button>
                                        </div>
                                    </div>
                                    <div class="col-md-2 text-end">
                                        <span class="item-total">৳@((item.Item.Price * item.Count).ToString("0.00"))</span>
                                        <button class="btn-remove" onclick="removeFromCart(@item.ItemId)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                                @if (item != Model.Last())
                                {
                                    <hr>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Order Summary</h5>
                        <hr>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <span id="subtotal">৳@ViewBag.Total.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Delivery Fee:</span>
                            <span>৳60.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total:</strong>
                            <strong id="total">৳@((ViewBag.Total + 60).ToString("0.00"))</strong>
                        </div>
                        <hr>
                        
                        <div class="mb-3">
                            <label class="form-label">Apply Coupon</label>
                            <div class="input-group">
                                <input type="text" id="couponCode" class="form-control" placeholder="Enter coupon code">
                                <button class="btn btn-outline-primary" onclick="applyCoupon()">Apply</button>
                            </div>
                        </div>
                        
                        <!-- ✅ এখানে লিংক ঠিক করা হয়েছে -->
                        <a href="/Order/Checkout" class="btn btn-primary w-100 py-2">
                            <i class="fas fa-credit-card"></i> Proceed to Checkout
                        </a>
                        <a href="/Home/Menu" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="fas fa-shopping-bag"></i> Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-cart text-center py-5">
            <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
            <h3>Your cart is empty</h3>
            <p>Looks like you haven't added any items to your cart yet.</p>
            <a href="/Home/Menu" class="btn btn-primary">Start Shopping</a>
        </div>
    }
</div>

<style>
    .cart-item {
        padding: 15px 0;
    }
    
    .quantity-control {
        display: flex;
        align-items: center;
        gap: 5px;
    }
    
    .btn-quantity {
        width: 30px;
        height: 30px;
        border: 1px solid #ddd;
        background: white;
        border-radius: 5px;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
        .btn-quantity:hover {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }
    
    .quantity-input {
        width: 50px;
        text-align: center;
        border: 1px solid #ddd;
        border-radius: 5px;
        padding: 5px;
    }
    
    .btn-remove {
        background: none;
        border: none;
        color: #ff4757;
        cursor: pointer;
        margin-left: 10px;
        transition: all 0.3s ease;
    }
    
        .btn-remove:hover {
            transform: scale(1.1);
        }
    
    .item-total {
        font-weight: bold;
        color: #667eea;
    }
    
    .empty-cart {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 60px;
    }
    
    @@media (max-width: 768px) {
        .cart-item .row > div {
            margin-bottom: 10px;
        }
        
        .quantity-control {
            justify-content: center;
        }
    }
</style>

<script>
    function updateQuantity(itemId, quantity) {
        if (quantity < 1) return;
        
        $.post('/Cart/UpdateQuantity', { itemId: itemId, quantity: quantity }, function(response) {
            if (response.success) {
                location.reload();
            }
        }).fail(function() {
            alert('Error updating quantity');
        });
    }
    
    function removeFromCart(itemId) {
        if (confirm('Are you sure you want to remove this item?')) {
            $.post('/Cart/RemoveFromCart', { itemId: itemId }, function(response) {
                if (response.success) {
                    location.reload();
                }
            }).fail(function() {
                alert('Error removing item');
            });
        }
    }
    
    function applyCoupon() {
        var coupon = $('#couponCode').val();
        if (coupon) {
            $.post('/Order/ApplyCoupon', { couponCode: coupon }, function(response) {
                if (response.success) {
                    alert('Coupon applied! You saved ৳' + response.discount);
                    location.reload();
                } else {
                    alert(response.message || 'Invalid coupon code');
                }
            });
        } else {
            alert('Please enter a coupon code');
        }
    }
</script>