@using FastsFood.ViewModel
@model ContactViewModel
@{
    ViewData["Title"] = "Contact Us - FastFood";
}

<!-- Hero Section -->
<section class="contact-hero">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold mb-4">Get In <span class="text-gradient">Touch</span></h1>
                <p class="lead">Have a question or feedback? We'd love to hear from you!</p>
            </div>
        </div>
    </div>
</section>

<!-- Contact Info Cards -->
<section class="contact-info py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="info-card text-center">
                    <div class="info-icon">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <h5>Visit Us</h5>
                    <p class="text-muted">123 Gulshan Avenue, Dhaka<br>Bangladesh</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-card text-center">
                    <div class="info-icon">
                        <i class="fas fa-phone-alt"></i>
                    </div>
                    <h5>Call Us</h5>
                    <p class="text-muted">+880 1234 567890<br>+880 1234 567891</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-card text-center">
                    <div class="info-icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <h5>Email Us</h5>
                    <p class="text-muted">info@fastfood.com<br>support@fastfood.com</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact Form & Map Section -->
<section class="contact-form-section py-5 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="form-card">
                    <h3 class="fw-bold mb-4">Send Us a Message</h3>
                    
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    
                    <form asp-action="Contact" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label">Your Name *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-user"></i></span>
                                    <input asp-for="Name" class="form-control" placeholder="Enter your name" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label">Email Address *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-envelope"></i></span>
                                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-phone"></i></span>
                                    <input asp-for="Phone" class="form-control" placeholder="Enter phone number" />
                                </div>
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                           
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Message" class="form-label">Message *</label>
                            <textarea asp-for="Message" class="form-control" rows="5" placeholder="Write your message here..."></textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 py-2">
                            <i class="fas fa-paper-plane me-2"></i> Send Message
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="col-lg-6">
                <div class="map-card">
                    <h3 class="fw-bold mb-4">Find Us</h3>
                    <div class="map-wrapper">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14607.458162925818!2d90.399924!3d23.780921!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3755c7d2e3d3d3d3%3A0x0!2zMjPCsDQ2JzUxLjMiTiA5MMKwMjQnMDQuNiJF!5e0!3m2!1sen!2sbd!4v1700000000000!5m2!1sen!2sbd"
                                width="100%"
                                height="300"
                                style="border:0; border-radius: 15px;"
                                allowfullscreen=""
                                loading="lazy">
                        </iframe>
                    </div>
                    
                    <div class="business-hours mt-4">
                        <h5><i class="fas fa-clock me-2 text-primary"></i> Business Hours</h5>
                        <div class="row mt-3">
                            <div class="col-6">
                                <p class="mb-1"><strong>Monday - Friday</strong></p>
                                <p class="text-muted">10:00 AM - 10:00 PM</p>
                            </div>
                            <div class="col-6">
                                <p class="mb-1"><strong>Saturday - Sunday</strong></p>
                                <p class="text-muted">11:00 AM - 11:00 PM</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="social-connect mt-4">
                        <h5><i class="fas fa-share-alt me-2 text-primary"></i> Connect With Us</h5>
                        <div class="social-links mt-3">
                            <a href="#" class="social-link facebook"><i class="fab fa-facebook-f"></i></a>
                            <a href="#" class="social-link instagram"><i class="fab fa-instagram"></i></a>
                            <a href="#" class="social-link twitter"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="social-link whatsapp"><i class="fab fa-whatsapp"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="faq-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill mb-3">
                <i class="fas fa-question-circle me-2"></i>FAQ
            </span>
            <h2 class="display-5 fw-bold">Frequently Asked Questions</h2>
            <p class="text-muted">Got questions? We've got answers</p>
        </div>
        
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="accordionFAQ">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                How long does delivery take?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#accordionFAQ">
                            <div class="accordion-body">
                                Delivery typically takes 30-45 minutes depending on your location. You'll receive real-time tracking updates once your order is confirmed.
                            </div>
                        </div>
                    </div>
                    
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                What payment methods do you accept?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#accordionFAQ">
                            <div class="accordion-body">
                                We accept Cash on Delivery, Credit/Debit Cards, bKash, Nagad, Rocket, and mobile banking through our secure payment gateway.
                            </div>
                        </div>
                    </div>
                    
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                Can I cancel my order?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#accordionFAQ">
                            <div class="accordion-body">
                                Yes, you can cancel your order within 5 minutes of placing it. Please contact our support team immediately for cancellation.
                            </div>
                        </div>
                    </div>
                    
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Do you have vegetarian options?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#accordionFAQ">
                            <div class="accordion-body">
                                Absolutely! We have a wide variety of vegetarian and vegan options clearly marked on our menu.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .contact-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 80px 0;
    }
    
    .text-gradient {
        background: linear-gradient(45deg, #ffd700, #fff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .info-card {
        background: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
    }
    
        .info-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 30px rgba(102,126,234,0.15);
        }
    
    .info-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #667eea15, #764ba215);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }
    
        .info-icon i {
            font-size: 2rem;
            color: #667eea;
        }
    
    .form-card, .map-card {
        background: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }
    
    .social-links {
        display: flex;
        gap: 15px;
    }
    
    .social-link {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        text-decoration: none;
    }
    
        .social-link.facebook {
            background: #1877f2;
            color: white;
        }
    
        .social-link.instagram {
            background: #e4405f;
            color: white;
        }
    
        .social-link.twitter {
            background: #1da1f2;
            color: white;
        }
    
        .social-link.whatsapp {
            background: #25d366;
            color: white;
        }
    
        .social-link:hover {
            transform: translateY(-3px);
            color: white;
            box-shadow: 0 5px 10px rgba(0,0,0,0.2);
        }
    
    .accordion-button:not(.collapsed) {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
    }
    
    .accordion-button:focus {
        box-shadow: none;
        border-color: #667eea;
    }
    
    @@media (max-width: 768px) {
        .contact-hero {
            padding: 60px 0;
        }

        .display-5 {
            font-size: 1.8rem;
        }
    }
</style>