@{
    ViewData["Title"] = "About Us - FastFood";
}

<!-- Hero Section -->
<section class="about-hero">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold mb-4">About <span class="text-gradient">FastFood</span></h1>
                <p class="lead">We're on a mission to deliver delicious, high-quality food right to your doorstep with love and care.</p>
            </div>
        </div>
    </div>
</section>

<!-- Our Story Section -->
<section class="our-story py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="story-content">
                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill mb-3">
                        <i class="fas fa-book-open me-2"></i>Our Story
                    </span>
                    <h2 class="display-5 fw-bold mb-4">Serving Happiness Since 2020</h2>
                    <p class="text-muted mb-3">FastFood started with a simple idea: to bring restaurant-quality food to your home without the wait. What began as a small kitchen in Dhaka has grown into a beloved food delivery service trusted by thousands of customers.</p>
                    <p class="text-muted mb-4">We believe that good food has the power to bring people together. That's why we source only the freshest ingredients and prepare every dish with passion and care. Our team works tirelessly to ensure that every bite brings a smile to your face.</p>
                    
                    <div class="row g-3 mt-3">
                        <div class="col-6">
                            <div class="stat-box">
                                <i class="fas fa-smile fa-2x text-primary mb-2"></i>
                                <h3 class="fw-bold mb-0">50K+</h3>
                                <p class="text-muted">Happy Customers</p>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-box">
                                <i class="fas fa-utensils fa-2x text-primary mb-2"></i>
                                <h3 class="fw-bold mb-0">200+</h3>
                                <p class="text-muted">Delicious Items</p>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-box">
                                <i class="fas fa-truck fa-2x text-primary mb-2"></i>
                                <h3 class="fw-bold mb-0">30min</h3>
                                <p class="text-muted">Fast Delivery</p>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-box">
                                <i class="fas fa-star fa-2x text-primary mb-2"></i>
                                <h3 class="fw-bold mb-0">4.9</h3>
                                <p class="text-muted">Customer Rating</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="story-image position-relative">
                    <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=600" alt="Our Story" class="img-fluid rounded-4 shadow-lg">
                    <div class="experience-badge">
                        <span>5+ Years of Excellence</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision Section -->
<section class="mission-vision py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card mission-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-primary bg-opacity-10 mx-auto mb-4">
                            <i class="fas fa-bullseye fa-2x text-primary"></i>
                        </div>
                        <h3 class="fw-bold mb-3">Our Mission</h3>
                        <p class="text-muted">To provide every customer with delicious, freshly prepared meals delivered quickly and affordably, while maintaining the highest standards of quality and hygiene.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card vision-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-success bg-opacity-10 mx-auto mb-4">
                            <i class="fas fa-eye fa-2x text-success"></i>
                        </div>
                        <h3 class="fw-bold mb-3">Our Vision</h3>
                        <p class="text-muted">To become the most loved and trusted food delivery service in the country, known for exceptional taste, speed, and customer satisfaction.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Core Values Section -->
<section class="core-values py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill mb-3">
                <i class="fas fa-heart me-2"></i>Core Values
            </span>
            <h2 class="display-5 fw-bold">What Drives Us</h2>
            <p class="text-muted">These core values guide everything we do</p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="value-card text-center">
                    <div class="value-icon">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h5>Quality First</h5>
                    <p class="text-muted">We never compromise on the quality of our ingredients</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="value-card text-center">
                    <div class="value-icon">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h5>Fast Delivery</h5>
                    <p class="text-muted">Speed without sacrificing quality or freshness</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="value-card text-center">
                    <div class="value-icon">
                        <i class="fas fa-smile"></i>
                    </div>
                    <h5>Customer First</h5>
                    <p class="text-muted">Your satisfaction is our top priority</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="value-card text-center">
                    <div class="value-icon">
                        <i class="fas fa-hand-sparkles"></i>
                    </div>
                    <h5>Hygiene & Safety</h5>
                    <p class="text-muted">Strict cleanliness protocols in every step</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill mb-3">
                <i class="fas fa-quote-left me-2"></i>Testimonials
            </span>
            <h2 class="display-5 fw-bold">What Our Customers Say</h2>
            <p class="text-muted">Don't just take our word for it</p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="rating mb-3">
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                    </div>
                    <p>"Amazing food quality! The delivery was super fast and the packaging was excellent. Highly recommended!"</p>
                    <div class="d-flex align-items-center mt-3">
                        <img src="https://randomuser.me/api/portraits/women/1.jpg" class="rounded-circle me-3" width="50" height="50">
                        <div>
                            <h6 class="mb-0">Sarah Ahmed</h6>
                            <small class="text-muted">Regular Customer</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="rating mb-3">
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                    </div>
                    <p>"Best food delivery service in Dhaka! The burgers are absolutely delicious and the prices are reasonable."</p>
                    <div class="d-flex align-items-center mt-3">
                        <img src="https://randomuser.me/api/portraits/men/1.jpg" class="rounded-circle me-3" width="50" height="50">
                        <div>
                            <h6 class="mb-0">Md. Rahman</h6>
                            <small class="text-muted">Food Lover</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="rating mb-3">
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star-half-alt text-warning"></i>
                    </div>
                    <p>"Quick delivery and fresh food. The pizza is my favorite! Will definitely order again and again."</p>
                    <div class="d-flex align-items-center mt-3">
                        <img src="https://randomuser.me/api/portraits/women/2.jpg" class="rounded-circle me-3" width="50" height="50">
                        <div>
                            <h6 class="mb-0">Tahmina Akter</h6>
                            <small class="text-muted">Pizza Lover</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .about-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 100px 0;
        margin-bottom: 0;
    }
    
    .text-gradient {
        background: linear-gradient(45deg, #ffd700, #fff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .stat-box {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 15px;
        text-align: center;
        transition: all 0.3s ease;
    }
    
        .stat-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
    
    .experience-badge {
        position: absolute;
        bottom: 20px;
        right: 20px;
        background: white;
        padding: 10px 20px;
        border-radius: 50px;
        font-weight: bold;
        color: #667eea;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    
    .icon-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .mission-card, .vision-card {
        border: none;
        border-radius: 20px;
        transition: all 0.3s ease;
    }
    
        .mission-card:hover, .vision-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 30px rgba(0,0,0,0.1);
        }
    
    .value-card {
        background: white;
        padding: 30px 20px;
        border-radius: 15px;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }
    
        .value-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(102,126,234,0.15);
        }
    
    .value-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #667eea15, #764ba215);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }
    
        .value-icon i {
            font-size: 2rem;
            color: #667eea;
        }
    
    .testimonial-card {
        background: white;
        padding: 25px;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        height: 100%;
    }
    
        .testimonial-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.12);
        }
    
    @@media (max-width: 768px) {
        .about-hero {
            padding: 60px 0;
        }

        .display-5 {
            font-size: 1.8rem;
        }
    }
</style>