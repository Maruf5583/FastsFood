@using FastsFood.ViewModel
@model MenuViewModel
@{
    ViewData["Title"] = "Our Menu - FastFood";
}

<style>
    /* Hero Section */
    .menu-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 60px 0;
        margin-bottom: 50px;
        position: relative;
        overflow: hidden;
    }
    
    .menu-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: repeating-linear-gradient(45deg, rgba(255,255,255,0.05) 0px, rgba(255,255,255,0.05) 2px, transparent 2px, transparent 8px);
        animation: shine 20s linear infinite;
    }
    
    @@keyframes shine {
        0% { transform: translateX(-100%) translateY(-100%) rotate(0deg); }
        100% { transform: translateX(100%) translateY(100%) rotate(360deg); }
    }
    
    /* Filter Sidebar */
    .filter-sidebar {
        position: sticky;
        top: 20px;
        border: none;
        border-radius: 20px;
        overflow: hidden;
    }
    
    .filter-header {
        background: linear-gradient(135deg, #667eea, #764ba2);
        padding: 15px 20px;
        color: white;
    }
    
    .filter-section {
        border-bottom: 1px solid #eee;
        padding: 15px 0;
    }
    
    .filter-section:last-child {
        border-bottom: none;
    }
    
    .filter-title {
        font-weight: 600;
        margin-bottom: 10px;
        color: #2c3e50;
    }
    
    /* Food Cards */
    .food-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        background: white;
        height: 100%;
        position: relative;
    }
    
    .food-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 30px rgba(102,126,234,0.2);
    }
    
    .card-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 2;
    }
    
    .badge-popular {
        background: #ff4757;
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }
    
    .badge-new {
        background: #28a745;
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }
    
    .card-img-wrapper {
        position: relative;
        height: 220px;
        overflow: hidden;
    }
    
    .card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    
    .food-card:hover .card-img {
        transform: scale(1.1);
    }
    
    .card-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
        padding: 20px;
        opacity: 0;
        transition: opacity 0.3s ease;
        display: flex;
        justify-content: center;
        gap: 10px;
    }
    
    .food-card:hover .card-overlay {
        opacity: 1;
    }
    
    .quick-view-btn {
        background: white;
        border: none;
        padding: 8px 15px;
        border-radius: 25px;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
    .quick-view-btn:hover {
        background: #667eea;
        color: white;
        transform: scale(1.05);
    }
    
    .card-content {
        padding: 20px;
    }
    
    .food-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: #2c3e50;
    }
    
    .food-category {
        display: inline-block;
        background: #f0f2ff;
        color: #667eea;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        margin-bottom: 10px;
    }
    
    .food-description {
        color: #7f8c8d;
        font-size: 0.85rem;
        line-height: 1.4;
        margin-bottom: 15px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .price-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .current-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: #667eea;
    }
    
    .old-price {
        font-size: 0.8rem;
        color: #bdc3c7;
        text-decoration: line-through;
        margin-left: 8px;
    }
    
    .order-btn {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 25px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .order-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 10px rgba(102,126,234,0.3);
    }
    
    /* Rating Stars */
    .rating {
        margin-bottom: 8px;
    }
    
    .rating i {
        font-size: 0.75rem;
        color: #ffc107;
    }
    
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px;
        background: #f8f9fa;
        border-radius: 20px;
    }
    
    /* Price Filter */
    .price-range {
        width: 100%;
        margin: 10px 0;
    }
    
    .price-values {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: #7f8c8d;
    }
    
    /* Responsive */
    @@media (max-width: 768px) {
        .filter-sidebar {
            position: static;
            margin-bottom: 30px;
        }
        
        .menu-hero {
            padding: 40px 0;
        }
        
        .menu-hero h1 {
            font-size: 1.8rem;
        }
    }
</style>

<!-- Hero Section -->
<section class="menu-hero">
    <div class="container">
        <div class="row text-center">
            <div class="col-lg-8 mx-auto">
                <h1 class="display-4 fw-bold text-white mb-3">Our Delicious Menu</h1>
                <p class="lead text-white-50">Explore our wide variety of mouth-watering dishes prepared with fresh ingredients</p>
            </div>
        </div>
    </div>
</section>

<div class="container pb-5">
    <div class="row g-4">
        <!-- Sidebar Filters -->
        <div class="col-lg-3">
            <div class="card filter-sidebar shadow-sm">
                <div class="filter-header">
                    <h5 class="mb-0"><i class="fas fa-filter me-2"></i> Filter Menu</h5>
                </div>
                <div class="card-body p-3">
                    <form method="get" asp-action="Menu" id="filterForm">
                        <!-- Search -->
                        <div class="filter-section">
                            <div class="filter-title">
                                <i class="fas fa-search me-2 text-primary"></i>Search
                            </div>
                            <div class="input-group">
                                <input type="text" name="searchTerm" class="form-control" value="@Model.SearchTerm" placeholder="Search items..." style="border-radius: 10px 0 0 10px;">
                                <button type="submit" class="btn btn-primary" style="border-radius: 0 10px 10px 0;">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Categories -->
                        <div class="filter-section">
                            <div class="filter-title">
                                <i class="fas fa-tags me-2 text-primary"></i>Categories
                            </div>
                            <select name="categoryId" class="form-select" id="categorySelect" style="border-radius: 10px;">
                                <option value="">All Categories</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.Id" selected="@(Model.SelectedCategoryId == cat.Id)">
                                        @cat.Title
                                    </option>
                                }
                            </select>
                        </div>

                        <!-- Sub Categories -->
                        <div class="filter-section" id="subCategoryDiv" style="@(Model.SelectedCategoryId.HasValue ? "display:block" : "display:none")">
                            <div class="filter-title">
                                <i class="fas fa-list me-2 text-primary"></i>Sub Categories
                            </div>
                            <select name="subCategoryId" class="form-select" id="subCategorySelect" style="border-radius: 10px;">
                                <option value="">All Sub Categories</option>
                                @if (Model.SubCategories != null)
                                {
                                    foreach (var sub in Model.SubCategories)
                                    {
                                        <option value="@sub.Id" selected="@(Model.SelectedSubCategoryId == sub.Id)">
                                            @sub.Title
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Price Range Filter -->
                        <div class="filter-section">
                            <div class="filter-title">
                                <i class="fas fa-dollar-sign me-2 text-primary"></i>Price Range
                            </div>
                            <input type="range" class="price-range" id="priceRange" min="0" max="1000" step="50" value="1000">
                            <div class="price-values">
                                <span>৳0</span>
                                <span>৳500</span>
                                <span>৳1000+</span>
                            </div>
                            <input type="hidden" name="maxPrice" id="maxPrice">
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-2" style="border-radius: 25px;">
                            <i class="fas fa-filter me-2"></i>Apply Filters
                        </button>
                        <a href="@Url.Action("Menu")" class="btn btn-outline-secondary w-100" style="border-radius: 25px;">
                            <i class="fas fa-undo-alt me-2"></i>Reset
                        </a>
                    </form>
                </div>
            </div>
        </div>

        <!-- Menu Items -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
                <div>
                    <h2 class="mb-0 fw-bold">Our Menu</h2>
                    <p class="text-muted mt-1">@Model.Items.Count delicious items found</p>
                </div>
                <div>
                    <select class="form-select" id="sortBy" style="border-radius: 25px; width: auto;">
                        <option value="default">Sort by: Default</option>
                        <option value="price_asc">Price: Low to High</option>
                        <option value="price_desc">Price: High to Low</option>
                        <option value="name_asc">Name: A to Z</option>
                    </select>
                </div>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-utensils fa-4x text-muted mb-3"></i>
                    <h4>No items found</h4>
                    <p class="text-muted">Try adjusting your filters or search term.</p>
                    <a href="@Url.Action("Menu")" class="btn btn-primary mt-3">Reset Filters</a>
                </div>
            }
            else
            {
                <div class="row g-4" id="itemsContainer">
                    @foreach (var item in Model.Items)
                    {
                        <div class="col-md-6 col-lg-4 food-item" data-price="@item.Price" data-name="@item.Title">
                            <div class="food-card">
                                @if (item.Price < 300)
                                {
                                    <div class="card-badge">
                                        <span class="badge-popular"><i class="fas fa-fire"></i> Popular</span>
                                    </div>
                                }
                                else if (item.Id % 5 == 0)
                                {
                                    <div class="card-badge">
                                        <span class="badge-new"><i class="fas fa-star"></i> New</span>
                                    </div>
                                }
                                
                                <div class="card-img-wrapper">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="card-img" alt="@item.Title" onerror="this.src='/images/items/cover.jpg'">
                                    }
                                    else
                                    {
                                        <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=400" class="card-img" alt="@item.Title">
                                    }
                                    <div class="card-overlay">
                                        <button class="quick-view-btn" onclick="quickView(@item.Id)">
                                            <i class="fas fa-eye"></i> Quick View
                                        </button>
                                    </div>
                                </div>
                                
                                <div class="card-content">
                                    <div class="rating">
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star-half-alt"></i>
                                        <span class="text-muted ms-1" style="font-size: 0.7rem;">(4.5)</span>
                                    </div>
                                    
                                    <h5 class="food-title">@item.Title</h5>
                                    <span class="food-category">@item.Category?.Title</span>
                                    <p class="food-description mt-2">@(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description ?? "Delicious food item prepared with fresh ingredients")</p>
                                    
                                    <div class="price-section">
                                        <div>
                                            <span class="current-price">৳@item.Price.ToString("0.00")</span>
                                            @if (item.Price > 500)
                                            {
                                                <span class="old-price">৳@((item.Price + 100).ToString("0.00"))</span>
                                            }
                                        </div>
                                        <button class="order-btn" onclick="addToCart(@item.Id)">
                                            <i class="fas fa-shopping-cart"></i> Order
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Quick View Modal -->
<div class="modal fade" id="quickViewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded-4">
            <div class="modal-body p-0">
                <div id="quickViewContent"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Category change
            $('#categorySelect').change(function() {
                var categoryId = $(this).val();
                if (categoryId) {
                    $.get('/Home/GetSubCategory', { CategoryId: categoryId }, function(data) {
                        var subSelect = $('#subCategorySelect');
                        subSelect.empty();
                        subSelect.append('<option value="">All Sub Categories</option>');
                        $.each(data, function(i, sub) {
                            subSelect.append('<option value="' + sub.id + '">' + sub.title + '</option>');
                        });
                        $('#subCategoryDiv').show();
                    });
                } else {
                    $('#subCategoryDiv').hide();
                    $('#subCategorySelect').empty();
                    $('#subCategorySelect').append('<option value="">All Sub Categories</option>');
                }
            });
            
            // Price range filter
            $('#priceRange').on('input', function() {
                $('#maxPrice').val($(this).val());
                $('#filterForm').submit();
            });
            
            // Sort functionality
            $('#sortBy').change(function() {
                var sortBy = $(this).val();
                var items = $('.food-item').get();
                
                items.sort(function(a, b) {
                    if (sortBy === 'price_asc') {
                        return $(a).data('price') - $(b).data('price');
                    } else if (sortBy === 'price_desc') {
                        return $(b).data('price') - $(a).data('price');
                    } else if (sortBy === 'name_asc') {
                        return $(a).data('name').localeCompare($(b).data('name'));
                    }
                    return 0;
                });
                
                $.each(items, function(index, item) {
                    $('#itemsContainer').append(item);
                });
            });
        });
        
        function quickView(itemId) {
            $.get('/Home/Details/' + itemId, function(data) {
                var html = `
                    <div class="quick-view-container">
                        <img src="${$(data).find('.item-image').attr('src') || '/images/items/cover.jpg'}" 
                             style="width: 100%; height: 250px; object-fit: cover;">
                        <div class="p-4">
                            <h3>${$(data).find('.item-title').text()}</h3>
                            <p>${$(data).find('.item-description').text()}</p>
                            <div class="price-tag">৳${$(data).find('.item-price').text()}</div>
                            <button class="btn btn-primary mt-3" onclick="addToCart(${itemId})">
                                Add to Cart
                            </button>
                        </div>
                    </div>
                `;
                $('#quickViewContent').html(html);
                $('#quickViewModal').modal('show');
            });
        }
        
        function addToCart(itemId) {
            @if (User.Identity.IsAuthenticated)
            {
                <text>
                    $.post('/Cart/AddToCart', { itemId: itemId }, function(response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Added to Cart!',
                                text: 'Item added to your cart successfully.',
                                showConfirmButton: false,
                                timer: 1500
                            });
                            updateCartCount();
                        }
                    });
                </text>
            }
            else
            {
                <text>
                    Swal.fire({
                        icon: 'warning',
                        title: 'Login Required',
                        text: 'Please login to add items to cart.',
                        showCancelButton: true,
                        confirmButtonText: 'Login'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '/Identity/Account/Login';
                        }
                    });
                </text>
            }
        }
        
        function updateCartCount() {
            $.get('/Cart/GetCartCount', function(count) {
                $('#cartCount').text(count);
            });
        }
    </script>
}