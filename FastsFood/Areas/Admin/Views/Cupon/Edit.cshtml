@model FastsFood.ViewModel.FastsFood.Models.CuponVm

@{
    ViewData["Title"] = "Edit Cupon";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-warning">
            <h3 class="card-title">Edit Cupon</h3>
            <div class="card-tools">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
        <form asp-action="Edit" enctype="multipart/form-data" method="post">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Title" class="control-label"></label>
                            <input asp-for="Title" class="form-control" placeholder="Enter cupon title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Type" class="control-label"></label>
                            <select asp-for="Type" class="form-control" asp-items="ViewBag.CuponTypes">
                                <option value="">-- Select Cupon Type --</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Discount" class="control-label"></label>
                            <div class="input-group">
                                <input asp-for="Discount" class="form-control" type="number" step="0.01" placeholder="Enter discount amount" />
                                <div class="input-group-append">
                                    <span class="input-group-text" id="discountSymbol">%</span>
                                </div>
                            </div>
                            <span asp-validation-for="Discount" class="text-danger"></span>
                            <small class="form-text text-muted">For Percentage type, enter value like 10, 20. For Amount type, enter value like 100, 200</small>
                        </div>

                        <div class="form-group">
                            <label asp-for="MinimumAmount" class="control-label"></label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">$</span>
                                </div>
                                <input asp-for="MinimumAmount" class="form-control" type="number" step="0.01" placeholder="Enter minimum order amount" />
                            </div>
                            <span asp-validation-for="MinimumAmount" class="text-danger"></span>
                            <small class="form-text text-muted">Minimum order amount required to apply this cupon</small>
                        </div>

                        <div class="form-group form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                            <small class="form-text text-muted">If active, this cupon will be available for customers</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Current Image</label>
                            @if (!string.IsNullOrEmpty(Model.ExistingImageBase64))
                            {
                                <div class="text-center mb-3">
                                    <img src="data:image/*;base64,@Model.ExistingImageBase64"
                                         alt="Current Cupon Image"
                                         style="max-width: 200px; max-height: 200px; border: 1px solid #ddd; padding: 5px;" />
                                    <br />
                                    <small class="text-muted">Current image</small>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info text-center">
                                    <i class="fas fa-image"></i> No image uploaded yet
                                </div>
                            }
                        </div>

                        <div class="form-group">
                            <label asp-for="CuponImageFile" class="control-label">Change Image (Optional)</label>
                            <input asp-for="CuponImageFile" class="form-control-file" type="file" accept="image/*" />
                            <span asp-validation-for="CuponImageFile" class="text-danger"></span>
                            <small class="form-text text-muted">
                                Upload new image to replace the existing one. Leave empty to keep current image.
                                <br />Supported formats: JPG, PNG, GIF
                            </small>
                        </div>

                        <div class="alert alert-info mt-3">
                            <i class="fas fa-info-circle"></i>
                            <strong>Note:</strong> If you upload a new image, it will replace the existing image.
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-warning">
                    <i class="fas fa-save"></i> Update
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        $(document).ready(function() {
            // Change discount symbol based on cupon type
            $('#Type').change(function() {
                var selectedType = $(this).val();
                if (selectedType === 'Percentage') {
                    $('#discountSymbol').text('%');
                    $('#Discount').attr('placeholder', 'Enter percentage (e.g., 10, 20)');
                    $('#Discount').attr('step', '1');
                } else if (selectedType === 'Amount') {
                    $('#discountSymbol').text('$');
                    $('#Discount').attr('placeholder', 'Enter amount (e.g., 100, 200)');
                    $('#Discount').attr('step', '0.01');
                } else {
                    $('#discountSymbol').text('%');
                }
            });
            
            // Trigger change on page load
            $('#Type').trigger('change');

            // Image preview for new image
            $('#CuponImageFile').change(function() {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        // Remove existing preview if any
                        $('.current-image-preview').remove();
                        
                        // Add new preview
                        var preview = '<div class="text-center mb-3 current-image-preview">' +
                                     '<label>New Image Preview:</label><br/>' +
                                     '<img src="' + e.target.result + '" ' +
                                     'style="max-width: 200px; max-height: 200px; border: 1px solid #ddd; padding: 5px;" />' +
                                     '<br/><small class="text-success">New image will replace current image</small>' +
                                     '</div>';
                        
                        $('.form-group:has(#CuponImageFile)').before(preview);
                    };
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>
}