@model FastsFood.ViewModel.FastsFood.Models.CuponVm

@{
    ViewData["Title"] = "Create Cupon";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Create New Cupon</h3>
            <div class="card-tools">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
        <form asp-action="Create" enctype="multipart/form-data" method="post">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Title" class="control-label"></label>
                            <input asp-for="Title" class="form-control" placeholder="Enter cupon title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Type" class="control-label"></label>
                            <select asp-for="Type" class="form-control" asp-items="ViewBag.CuponTypes">
                                <option value="">-- Select Cupon Type --</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Discount" class="control-label"></label>
                            <div class="input-group">
                                <input asp-for="Discount" class="form-control" type="number" step="0.01" placeholder="Enter discount amount" />
                                <div class="input-group-append">
                                    <span class="input-group-text" id="discountSymbol">%</span>
                                </div>
                            </div>
                            <span asp-validation-for="Discount" class="text-danger"></span>
                            <small class="form-text text-muted">For Percentage type, enter value like 10, 20. For Amount type, enter value like 100, 200</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="MinimumAmount" class="control-label"></label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">$</span>
                                </div>
                                <input asp-for="MinimumAmount" class="form-control" type="number" step="0.01" placeholder="Enter minimum order amount" />
                            </div>
                            <span asp-validation-for="MinimumAmount" class="text-danger"></span>
                            <small class="form-text text-muted">Minimum order amount required to apply this cupon</small>
                        </div>

                        <div class="form-group">
                            <label asp-for="CuponImageFile" class="control-label"></label>
                            <input asp-for="CuponImageFile" class="form-control-file" type="file" accept="image/*" />
                            <span asp-validation-for="CuponImageFile" class="text-danger"></span>
                            <small class="form-text text-muted">Optional: Upload cupon image/icon (JPG, PNG, GIF)</small>
                        </div>

                        <div class="form-group form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                            <small class="form-text text-muted">If active, this cupon will be available for customers</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Create
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        $(document).ready(function() {
            // Change discount symbol based on cupon type
            $('#Type').change(function() {
                var selectedType = $(this).val();
                if (selectedType === 'Percentage') {
                    $('#discountSymbol').text('%');
                    $('#Discount').attr('placeholder', 'Enter percentage (e.g., 10, 20)');
                } else if (selectedType === 'Amount') {
                    $('#discountSymbol').text('$');
                    $('#Discount').attr('placeholder', 'Enter amount (e.g., 100, 200)');
                } else {
                    $('#discountSymbol').text('%');
                }
            });
            
            // Trigger change on page load
            $('#Type').trigger('change');
        });
    </script>
}