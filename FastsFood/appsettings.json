    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "your-email@gmail.com",
    "SenderPassword": "your-app-password",
    "EnableSSL": true
  },

  // Site Settings
  "SiteSettings": {
    "SiteName": "FastFood",
    "SiteUrl": "https://localhost:44329",
    "AdminEmail": "admin@fastfood.com",
    "DeliveryFee": 60,
    "FreeDeliveryAmount": 1000
  },

  // Payment Settings
  "PaymentSettings": {
    "CashOnDelivery": true,
    "SSLCommerz": true,
    "TestPayment": true
  }
