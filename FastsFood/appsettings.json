  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // SSLCommerz Configuration
  "SSLCommerz": {
    "StoreId": "testbox",
    "StorePassword": "qwerty123",
